<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiaolong.cm.merch.mapper.CmProductLabelMapper">

	<insert id="insertBatch">
		insert into cm_product_label (product_id, label_id) values
		<foreach collection="labelSet" item="labelId" index="i" separator=",">
			(#{productId}, #{labelId})
		</foreach>
	</insert>

	<delete id="deleteByProductId">
		delete from cm_product_label where product_id = #{productId}
	</delete>
</mapper>
