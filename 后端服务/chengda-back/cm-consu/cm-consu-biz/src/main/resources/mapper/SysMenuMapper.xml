<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiaolong.cm.consu.mapper.SysMenuMapper">

	<select id="findMenuByRoleId" resultType="java.lang.String" parameterType="java.lang.Long">
		select permission from sys_menu sm
		    left join sys_role_menu srm on sm.menu_id = srm.menu_id where srm.role_id = #{roleId}
	</select>
</mapper>
